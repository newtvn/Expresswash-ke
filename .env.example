# ============================================================
# ExpressWash - Environment Variables
# Copy this file to .env and fill in your values
# ============================================================

# ── Supabase (REQUIRED) ─────────────────────────────────────
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# ── App Configuration ───────────────────────────────────────
VITE_APP_NAME=ExpressWash
VITE_APP_VERSION=1.0.0

# ── Session ─────────────────────────────────────────────────
VITE_SESSION_TIMEOUT_MINUTES=30

# ── Google Maps (for driver location tracking) ───────────────
# Get key from: https://console.cloud.google.com/
# Enable: Maps JavaScript API, Geocoding API
VITE_GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# ── M-Pesa / Africa's Talking ─────────────────────────────────
# All payment and SMS credentials are server-side only (Edge Functions).
# No VITE_ env vars needed for M-Pesa or Africa's Talking.

# ── Sentry (error monitoring) ──────────────────────────────
# Get DSN from: https://sentry.io/ → Project Settings → Client Keys
VITE_SENTRY_DSN=

# ── Web Push (VAPID) ──────────────────────────────────────
# Generate keys with: npx web-push generate-vapid-keys
VITE_VAPID_PUBLIC_KEY=

# ── Legacy REST API (not used when Supabase is active) ────────
# Only needed if you add a separate Node backend
# VITE_API_URL=http://localhost:3001/api
