# ============================================================
# ExpressWash - Environment Variables
# Copy this file to .env and fill in your values
# ============================================================

# ── Supabase (REQUIRED) ─────────────────────────────────────
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# ── App Configuration ───────────────────────────────────────
VITE_APP_NAME=ExpressWash
VITE_APP_VERSION=1.0.0

# ── Session ─────────────────────────────────────────────────
VITE_SESSION_TIMEOUT_MINUTES=30

# ── Google Maps (for driver location tracking) ───────────────
# Get key from: https://console.cloud.google.com/
# Enable: Maps JavaScript API, Geocoding API
VITE_GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# ── M-Pesa / Daraja API (payment integration) ────────────────
# Obtained from: https://developer.safaricom.co.ke/
# These should be stored server-side; expose only the public key here
VITE_MPESA_SHORTCODE=174379
VITE_MPESA_ENV=sandbox

# ── Africa's Talking (SMS / USSD notifications) ──────────────
# Obtained from: https://africastalking.com/
# API credentials must be server-side; expose only username
VITE_AT_USERNAME=sandbox
VITE_AT_ENV=sandbox

# ── Feature Flags ────────────────────────────────────────────
# Set to false when Supabase is connected; true uses hardcoded mock data
VITE_USE_MOCK_DATA=true

# ── Legacy REST API (not used when Supabase is active) ────────
# Only needed if you add a separate Node backend
# VITE_API_URL=http://localhost:3001/api
